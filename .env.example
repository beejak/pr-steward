# GitHub token for pr-lifecycle apply job (write-scoped; CI only)
# GITHUB_TOKEN is provided automatically in GitHub Actions

# Cross-repo fixture runs (beejak/agentwatch) — PAT with repo scope on target
# AGENTWATCH_TOKEN=

# Override target repo (local or workflow_dispatch)
# PR_STEWARD_TARGET_REPO=beejak/agentwatch

# Agent triage: auto | deepseek | cursor | heuristic
# PR_STEWARD_TRIAGE_PROVIDER=auto

# DeepSeek API (recommended — same family as WatchTower verdict judge)
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Cursor SDK (optional — repo-aware cloud agent)
# CURSOR_API_KEY=

# GitLab project access token (api scope) for MR operations
# GITLAB_TOKEN=
