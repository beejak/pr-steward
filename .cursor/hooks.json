{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/security-check.sh",
        "failClosed": false
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/guard-git-commit.sh",
        "matcher": "git\\s+commit",
        "failClosed": false
      }
    ]
  }
}
