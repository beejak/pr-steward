{
  "name": "pr-steward",
  "version": "0.1.0",
  "private": true,
  "description": "Hybrid multi-platform PR lifecycle automation (close, warn, security signals)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && npm run lint",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pr-lifecycle:dry-run": "node --import tsx src/cli/dry-run.ts",
    "pr-lifecycle:run": "node --import tsx src/cli/run.ts",
    "docs:curate": "node --import tsx src/cli/curate-docs.ts",
    "security:scan": "make security-scan"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "yaml": "^2.7.0"
  },
  "dependencies": {},
  "optionalDependencies": {
    "@cursor/sdk": "^0.1.0"
  }
}
